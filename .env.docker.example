# ============================================================
# Nivas PMS — Unified Docker Environment
# Copy to .env.docker and fill in real values.
# Used by:
#   docker compose --env-file .env.docker up --build
#   docker compose -f docker-compose.prod.yml --env-file .env.docker up --build -d
#   docker compose -f docker-compose.platform.yml --env-file .env.docker up --build -d
#
# This single file replaces:
#   services/backend/.env  AND  apps/web/.env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=nivas_db

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=change-this-to-a-strong-redis-password

# ── MinIO (S3-compatible object storage) ────────────────────
MINIO_ACCESS_KEY=nivas_minio
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_BUCKET=nivas
MINIO_BACKUP_BUCKET=nivas-backups
# Days before an unreferenced upload is eligible for orphan cleanup
MINIO_ORPHAN_MIN_AGE_DAYS=7
# Browser-reachable URL for images. In production, point your
# domain/reverse-proxy at MinIO :9000 and set this to
# https://yourdomain.com/storage
MINIO_PUBLIC_URL=http://localhost:9000

# ── Backend: Core ───────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Generate: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-32-char-secret-minimum
JWT_EXPIRY=7d
# Comma-separated allowed origins (browser / Expo web)
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,exp://*

# ── Backend: Database ───────────────────────────────────────
# Auto-composed from POSTGRES_PASSWORD/POSTGRES_DB in docker-compose.
# Override here only if you need a custom connection string.
# DATABASE_URL=postgres://postgres:changeme@pgbouncer:5432/nivas_db
# DATABASE_DIRECT_URL=postgres://postgres:changeme@postgres:5432/nivas_db
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=15

# ── Backend: Redis ──────────────────────────────────────────
# Auto-composed from REDIS_PASSWORD in docker-compose.
# Override here only if you need a custom connection string.
# REDIS_URL=redis://:password@redis:6379

# ── Backend: Super Admin (first-time seed) ──────────────────
SUPER_ADMIN_EMAIL=admin@nivaspms.com
SUPER_ADMIN_PASSWORD=change-this-super-admin-password
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=9800000000

# ── Backend: Guest Portal ───────────────────────────────────
GUEST_PORTAL_URL=http://localhost

# ── Backend: Logging ────────────────────────────────────────
# error | warn | info | debug — use warn in production
LOG_LEVEL=info
# Fraction of requests to log in production (0–1)
LOG_SAMPLE_RATE=0.05
# API docs at /docs — off in production unless explicitly enabled
ENABLE_SWAGGER=false

# ── Backend: API / Server ───────────────────────────────────
# Set to true when running behind a reverse proxy (nginx, Traefik, ALB)
TRUST_PROXY=false
# Public base URL used in QR codes, email links, and webhooks
API_BASE_URL=http://localhost
# Request timeout in ms
REQUEST_TIMEOUT_MS=30000
# Max payload size in bytes (default: 10MB)
MAX_BODY_SIZE=10485760
# Max file upload size in bytes
MAX_FILE_SIZE=10485760

# ── Backend: AI Engine (Gemini Flash) ───────────────────────
# Each hotel brings its OWN Gemini API key + model in Settings → General → AI.
# There is no platform/.env key. Only override the provider endpoint if not
# using Google Gemini (rare):
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# ── Backend: IRD CBMS (Nepal e-billing — optional) ──────────
CBMS_BILL_URL=https://cbapi.ird.gov.np/api/bill
CBMS_RETURN_URL=https://cbapi.ird.gov.np/api/billreturn

# ── Backend: Database Backups ───────────────────────────────
# How many backups to retain (older ones auto-deleted)
BACKUP_KEEP=3
# Max ms for pg_dump before killing (default: 300000 = 5 min)
BACKUP_TIMEOUT_MS=300000
# Temp dir for streaming pg_dump (defaults to OS temp)
# BACKUP_TMP_DIR=/tmp

# ── Backend: SaaS Admin SMTP / SMS (fallback — optional) ────
# Used ONLY for super-admin 2FA OTP, SaaS billing emails.
# NEVER used as fallback for tenant notifications.
# DEFAULT_SMTP_HOST=smtp.gmail.com
# DEFAULT_SMTP_PORT=587
# DEFAULT_SMTP_USER=saas@yourdomain.com
# DEFAULT_SMTP_PASSWORD=app-specific-password
# DEFAULT_SMTP_FROM_EMAIL=saas@yourdomain.com
# DEFAULT_SMTP_FROM_NAME=Nivas PMS
# DEFAULT_SMS_PROVIDER=SPARROW
# DEFAULT_SMS_API_KEY=your-sms-api-key
# DEFAULT_SMS_API_SECRET=your-sms-api-secret
# DEFAULT_SMS_SENDER_ID=NivasPMS

# ── Backend: Mobile Analytics (optional) ────────────────────
# OFF by default. Set to true to opt in.
# MOBILE_ANALYTICS_ENABLED=false
# MOBILE_ANALYTICS_RETENTION_DAYS=30

# ── Backend: Dev-only flags ─────────────────────────────────
# Log super-admin 2FA OTP to stdout (dev only — NEVER in production)
# DEV_LOG_OTP=true

# ── Frontend ────────────────────────────────────────────────
# Port exposed by the frontend container (nginx in prod, Bun dev in dev)
FRONTEND_PORT=80
# Backend API URL — Docker internal: use service name "backend"
BACKEND_URL=http://backend:3000
# Client-side API path (relative — goes through nginx proxy)
BASE_API_URL=/api/v1
# Client-side WebSocket URL (optional — if unset, falls back to window.location)
# VITE_API_URL=http://localhost:3000
# VITE_WS_URL=ws://localhost:3000

# ── Resource limits (production — optional) ─────────────────
# PG_MEM_LIMIT=768M
# REDIS_MEM_LIMIT=640M
# MINIO_MEM_LIMIT=384M
# BACKEND_MEM_LIMIT=512M
# FRONTEND_MEM_LIMIT=128M
# PLATFORM_MEM_LIMIT=768M   # all-in-one image (backend+nginx)
